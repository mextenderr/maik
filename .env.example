# --- SMTP (outgoing mail) ---
# Strato: confirm exact host/port in your Strato Webmail → e-mail settings.
SMTP_HOST="smtp.strato.de"
# 465 = SSL/TLS (recommended), or 587 = STARTTLS
SMTP_PORT="465"
# Full mailbox address used to authenticate AND send from.
SMTP_USER="noreply@maikvanvelthoven.nl"
# The mailbox password (Strato uses the normal mailbox password — no app password needed).
SMTP_PASSWORD="your-mailbox-password"

# Where contact-form submissions are delivered.
# Optional — defaults to SMTP_USER if omitted.
CONTACT_TO_EMAIL="info@maikvanvelthoven.nl"

# Optional: override the visible "from" address (must be an address this mailbox may send as).
# Defaults to SMTP_USER.
# MAIL_FROM="noreply@maikvanvelthoven.nl"
