# Copy to .devcontainer/.env and fill in (optional). This file is read by the
# container via runArgs --env-file in devcontainer.json. A .devcontainer/.env
# must exist for the container to start (even if empty) — it is gitignored.

# Optional: GitHub CLI auth, so `gh` works inside the container without an
# interactive login. Fine-grained token scoped to mextenderr/maik.
# Generate at https://github.com/settings/personal-access-tokens
GH_TOKEN=
